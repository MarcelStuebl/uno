<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:id="rootPanel"
      fx:controller="htl.steyr.uno.GameTableClasses.EnemyDisplayController"
      stylesheets="@style/GameTableStyle.css"
      styleClass="player-panel"
      spacing="12"
      alignment="CENTER_LEFT"
      prefWidth="280" minWidth="280" maxWidth="280"
      prefHeight="90"  minHeight="90"  maxHeight="90">
    <padding>
        <Insets top="12" right="16" bottom="12" left="12"/>
    </padding>

    <!-- Profilbild -->
    <ImageView fx:id="profileImageView"
               fitWidth="56" fitHeight="56"
               preserveRatio="true" pickOnBounds="true"/>

    <!-- Name + Karten -->
    <VBox spacing="8" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
        <Label fx:id="usernameLabel"
               text="Spieler"
               styleClass="player-name"
               minWidth="120" maxWidth="160"/>
        <Pane fx:id="cardPane"
              prefWidth="150" minWidth="150" maxWidth="150"
              prefHeight="44" minHeight="44" maxHeight="44"
              styleClass="card-pane"/>
    </VBox>
</HBox>