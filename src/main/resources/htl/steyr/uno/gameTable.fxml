<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="root" stylesheets="@style/GameTableStyle.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <Pane fx:id="table" styleClass="table" StackPane.alignment="CENTER" />

        <StackPane fx:id="enemy1" maxHeight="100" maxWidth="320" minHeight="100" minWidth="320" StackPane.alignment="TOP_CENTER" />
        <StackPane fx:id="enemy2" maxHeight="100" maxWidth="320" minHeight="100" minWidth="320" StackPane.alignment="CENTER_LEFT" />
        <StackPane fx:id="enemy3" maxHeight="100" maxWidth="320" minHeight="100" minWidth="320" StackPane.alignment="CENTER_RIGHT" />

    </children>
</StackPane>
