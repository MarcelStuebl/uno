<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="400.0" prefWidth="600.0" stylesheets="@style/lobbyWaitStyle.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1">

    <children>

        <!-- LINKER BEREICH: Hauptinhalt (skaliert mit) -->
        <BorderPane styleClass="mainPaine" HBox.hgrow="ALWAYS">

            <top>
                <VBox alignment="TOP_CENTER">
                    <children>
                        <AnchorPane>
                            <children>
                                <Label fx:id="lobbyCodeLabel" alignment="CENTER" styleClass="lobbyCodeLabel" text="LobbyCode:" AnchorPane.bottomAnchor="8.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="8.0">
                                    <font>
                                        <Font size="30.0" />
                                    </font>
                                </Label>
                            </children>
                        </AnchorPane>

                        <Line endX="200.0" startX="-200.0" strokeWidth="2.0" />
                    </children>
                </VBox>
            </top>

            <!-- Center: SplitPane, damit der Chat „ausgeklappt“ werden kann (Divider ziehen) -->
            <center>
                <SplitPane dividerPositions="0.65" orientation="VERTICAL" styleClass="splitPane">
                    <items>

                        <!-- Spieler-Liste (nimmt automatisch Platz) -->
                        <VBox prefHeight="111.0" prefWidth="0.0">
                            <children>
                                <ListView fx:id="playerListView" prefHeight="100.0" prefWidth="306.0" styleClass="playerListView" />
                            </children>
                            <padding>
                                <Insets bottom="0" left="0" right="0" top="0" />
                            </padding>
                        </VBox>

                        <!-- Chat-Bereich (ausklappbar über SplitPane-Divider) -->
                        <VBox spacing="8.0">
                            <children>
                                <ListView fx:id="gameChatListView" prefHeight="13.0" prefWidth="299.0" styleClass="gameChatListView" />

                                <AnchorPane styleClass="chatPane">
                                    <children>
                                        <TextField fx:id="gameChatTextField" layoutX="79.0" onAction="#onSendMassage" prefHeight="25.0" prefWidth="242.0" styleClass="gameChatTextField" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="79.0" AnchorPane.rightAnchor="79.0" AnchorPane.topAnchor="0.0" />
                                    </children>
                                </AnchorPane>
                            </children>
                            <padding>
                                <Insets bottom="12" left="0" right="0" top="0" />
                            </padding>
                        </VBox>

                    </items>
                </SplitPane>
            </center>

            <padding>
                <Insets bottom="12" left="12" right="12" top="12" />
            </padding>
        </BorderPane>

        <!-- RECHTER BEREICH: Seitenleiste (fixer, aber sauber skalierbar) -->
        <VBox minWidth="180.0" prefWidth="200.0" styleClass="secondaryPane">
            <children>

                <Label fx:id="AccNameDisplayLabel" maxWidth="1.7976931348623157E308" styleClass="labels" text="Acc Name">
                    <font>
                        <Font size="18.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="8" left="12" right="12" top="12" />
                    </VBox.margin>
                </Label>

                <Line endX="120.0" startX="-120.0" strokeWidth="2.0">
                    <VBox.margin>
                        <Insets bottom="12" left="12" right="12" top="0" />
                    </VBox.margin>
                </Line>

                <VBox spacing="12.0" VBox.vgrow="ALWAYS">
                    <children>

                        <Button fx:id="playButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#playButtonClicked" styleClass="playButton" text="Spielen" />

                        <!-- Füller, damit "Lobby verlassen" unten bleibt -->
                        <VBox VBox.vgrow="ALWAYS" />

                        <Button fx:id="leaveLobbyButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#leaveLobbyButtonClicked" styleClass="leaveButton" text="Lobby verlassen" />
                    </children>

                    <padding>
                        <Insets bottom="12" left="12" right="12" top="12" />
                    </padding>
                </VBox>

            </children>
        </VBox>

    </children>
</HBox>
